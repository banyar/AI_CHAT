# ============================================================
# Frontiir AI Chat — Example Config (git-safe template)
# ============================================================
# ဤ file ကို copy လုပ်ပြီး .env အဖြစ် သိမ်းပြီး တန်ဖိုးများ ထည့်ပါ
#   cp .env.example .env
# ============================================================

# LLM provider: "ollama" or "gemini"
LLM_PROVIDER=ollama

# Gemini (LLM_PROVIDER=gemini ဆိုမှ လိုတယ်)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# Ollama (LLM_PROVIDER=ollama ဆိုမှ လိုတယ်)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=frontiir-ai:latest

QDRANT_URL=http://localhost:6333

CPE_API_URL=http://localhost:9000/api/cpe

CUSTOMER_API_URL=http://localhost:9000/api/customer
